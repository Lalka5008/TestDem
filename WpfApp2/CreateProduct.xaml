<Window x:Class="WpfApp2.CreateProduct"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp2"
        mc:Ignorable="d"
        FontFamily="Times New Roman"     
        Title="Создать продукт" Height="450" Width="475" Icon="/Icon.ico">
    <Grid>

        <StackPanel>
            <TextBlock Text="Артикул" />
            <TextBox x:Name="ArtBox" HorizontalAlignment="Left" TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" Width="120"/>
            <TextBlock Text="Тип продукта" />
            <TextBox x:Name="TypeBox" HorizontalAlignment="Left"  TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" Width="120"/>
            <TextBlock Text="Тип кол-ва" />
            <TextBox x:Name="UnitBox" HorizontalAlignment="Left" TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" Width="120"/>
            <TextBlock Text="Цена" />
            <TextBox x:Name="PriceBox" HorizontalAlignment="Left"  TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" Width="120"/>
            <TextBlock Text="Поставщик" />
            <TextBox x:Name="ImportBox" HorizontalAlignment="Left"  TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" Width="120"/>
            <TextBlock Text="Производитель" />
            <TextBox x:Name="CreaterBox" HorizontalAlignment="Left"  TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" Width="120"/>
            <TextBlock Text="Категория" />
            <TextBox x:Name="CategoryBox" HorizontalAlignment="Left"  TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" Width="120"/>
            <TextBlock Text="Скидка" />
            <TextBox x:Name="SaleBox" HorizontalAlignment="Left"  TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" Width="120"/>
            <TextBlock Text="Кол-во" />
            <TextBox x:Name="QuantityBox" HorizontalAlignment="Left"  TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" Width="120"/>
            <TextBlock Text="Инфо" />
            <TextBox x:Name="InfoBox" HorizontalAlignment="Left"  TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" Width="120"/>
            <TextBlock Text="Изображение" />
            <TextBox x:Name="ImageBox" HorizontalAlignment="Left"  TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" Width="120"/>
            <Button Content ="Создать заявку" Height="31" Width="135" Click="Button_Click" />
        </StackPanel>

    </Grid>
</Window>
